  "custom_css": "/* WebPrinter / Ainexa: hide HFE/Hello-Elementor default site-header \u2014 kit hero section already contains the real nav. */\n#site-header { display: none !important; }\n/* (Removed footer#colophon { display:none } rule \u2014 HFE 2.8+ wraps the kit footer INSIDE <footer id=\"colophon\">, so hiding it killed the whole footer.) */\n/* === WP Pilot TEA-756: hero polish + footer contrast (CSS-only, no engine change) === */\nhtml, body { overflow-x: hidden; }\n.elementor *, .elementor-heading-title,\n.elementor-widget-heading h1, .elementor-widget-heading h2, .elementor-widget-heading h3 {\n  word-wrap: break-word !important;\n  overflow-wrap: anywhere !important;\n  max-width: 100% !important;\n}\n.elementor-section, .elementor-container, .e-con, .e-con-inner { max-width: 100% !important; }\n\n/* Tame the 100vh hero \u2014 let content drive height, prevent giant black voids */\n.elementor-section.elementor-section-height-default,\n.elementor-section[data-element_type=\"section\"]:first-of-type,\n.e-con[data-element_type=\"container\"]:first-child {\n  min-height: auto !important;\n}\n\n/* Hide orphan stat counters in hero (no real data, render \"10x\"/\"3\" with no labels) */\n.elementor-widget-counter { display: none !important; }\n\n/* Hide broken hero overlays: INTRODUCING repeater (clones once per testimonial),\n   animated-headline placeholder, and the duplicate header trial-CTA */\n.elementor-widget-tp-heading-title { display: none !important; }\n.elementor-widget-animated-headline { display: none !important; }\n.elementor-widget-mdp-buttoner-elementor { display: none !important; }\n\n/* Footer contrast: HFE renders dark-on-dark; lift to readable on dark theme */\nfooter.elementor-location-footer,\nfooter.elementor-location-footer *,\n.hfe-footer, .hfe-footer * { color: #e8e8e8 !important; }\nfooter.elementor-location-footer a, .hfe-footer a { color: #00d4ff !important; }\nfooter.elementor-location-footer h1,\nfooter.elementor-location-footer h2,\nfooter.elementor-location-footer h3,\nfooter.elementor-location-footer .elementor-heading-title { color: #ffffff !important; }\n\n\n/* === WP Pilot TEA-756 v2: Hello Elementor leak cleanup + button sanity === */\n\n/* (v2 hello-header hide removed \u2014 vision needs visible brand-in-header credit) */\n/* (v2 :has() stat-card hide removed \u2014 it matched ancestor containers and hid the whole hero) */\n/* Tame the oversized hero CTA circle button (kit makes it ~280px round). */\n.elementor-widget-button .elementor-button {\n  max-width: 240px !important;\n  padding: 16px 28px !important;\n  border-radius: 999px !important;\n  height: auto !important;\n  width: auto !important;\n}\n\n"

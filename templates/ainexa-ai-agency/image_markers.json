{
  "_format_version": "1.0",
  "_template": "ainexa-ai-agency",
  "_notes": "Image markers that n8n workflow A6naBMqLH3eRDzjx must replace per-site before WordPress import. Decorative design assets (icons, backgrounds, shapes) are self-hosted in ./assets/ and referenced via raw.githubusercontent.com URLs in the template JSON — they do NOT need injection.",
  "markers": {
    "IMAGE_HOME_HERO_FEATURE": {
      "role": "hero_feature_photo",
      "location": "home.json",
      "description": "Hero-section feature photo. Contextual to business (laptop/computing/AI for agencies, on-site work for trades). Landscape orientation.",
      "fallback_category": "generic"
    },
    "IMAGE_CONTACT_TEAM_LEAD": {
      "role": "team_portrait",
      "location": "contact.json (background_video_fallback)",
      "description": "Single portrait photo, used as video poster on contact page. Person speaking / addressing camera.",
      "fallback_category": "team"
    },
    "IMAGE_ABOUT_HERO": {
      "role": "team_action_photo",
      "location": "about.json (about-section background)",
      "description": "Team-at-work photo. Multi-person, collaborative.",
      "fallback_category": "team"
    },
    "IMAGE_ABOUT_FEATURE_1": {
      "role": "feature_photo",
      "location": "about.json",
      "description": "Brainstorming / collaboration photo.",
      "fallback_category": "team"
    },
    "IMAGE_ABOUT_FEATURE_2": {
      "role": "feature_photo",
      "location": "about.json",
      "description": "Technology / process feature photo.",
      "fallback_category": "action"
    },
    "IMAGE_ABOUT_FEATURE_3": {
      "role": "feature_photo",
      "location": "about.json",
      "description": "Office / team-in-environment photo.",
      "fallback_category": "team"
    },
    "IMAGE_ABOUT_TEAM_1": { "role": "team_member_portrait", "location": "about.json", "slot": 1, "fallback_category": "team" },
    "IMAGE_ABOUT_TEAM_2": { "role": "team_member_portrait", "location": "about.json", "slot": 2, "fallback_category": "team" },
    "IMAGE_ABOUT_TEAM_3": { "role": "team_member_portrait", "location": "about.json", "slot": 3, "fallback_category": "team" },
    "IMAGE_ABOUT_TEAM_4": { "role": "team_member_portrait", "location": "about.json", "slot": 4, "fallback_category": "team" },
    "IMAGE_ABOUT_TEAM_5": { "role": "team_member_portrait", "location": "about.json", "slot": 5, "fallback_category": "team" },
    "IMAGE_ABOUT_TEAM_6": { "role": "team_member_portrait", "location": "about.json", "slot": 6, "fallback_category": "team" },
    "IMAGE_ABOUT_TEAM_7": { "role": "team_member_portrait", "location": "about.json", "slot": 7, "fallback_category": "team" },
    "IMAGE_ABOUT_TEAM_8": { "role": "team_member_portrait", "location": "about.json", "slot": 8, "fallback_category": "team" },
    "IMAGE_SERVICES_FEATURE_CHART": {
      "role": "feature_photo",
      "location": "services.json",
      "description": "Stats / data / chart visual.",
      "fallback_category": "generic"

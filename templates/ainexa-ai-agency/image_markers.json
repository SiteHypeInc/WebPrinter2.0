    "IMAGE_TESTIMONIAL_1": { "role": "testimonial_portrait", "location": "services.json", "slot": 1, "fallback_category": "team" },
    "IMAGE_TESTIMONIAL_2": { "role": "testimonial_portrait", "location": "services.json", "slot": 2, "fallback_category": "team" },
    "IMAGE_TESTIMONIAL_3": { "role": "testimonial_portrait", "location": "services.json", "slot": 3, "fallback_category": "team" },
    "IMAGE_TESTIMONIAL_4": { "role": "testimonial_portrait", "location": "services.json", "slot": 4, "fallback_category": "team" },
    "IMAGE_TESTIMONIAL_5": { "role": "testimonial_portrait", "location": "services.json", "slot": 5, "fallback_category": "team" },
    "IMAGE_BADGE_1": {
      "role": "social_proof_badge",
      "location": "footer.json + home.json (used twice)",

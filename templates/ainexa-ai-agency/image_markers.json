    "IMAGE_BADGE_3": {
      "role": "social_proof_badge",
      "location": "footer.json + home.json (used twice)",
      "description": "Certification/affiliation badge slot 3. Original template used Clutch.",
      "fallback_category": null,
      "default_when_empty": "remove_element"
    }
